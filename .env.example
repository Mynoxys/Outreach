# Copy this to .env.local for local dev (npm run dev), and set the SAME two
# variables in your host (Vercel: Project → Settings → Environment Variables).
# The anon key is meant to be public — it's safe to expose in the built site.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Only needed for a GitHub Pages *project* site served from /<repo>/.
# Leave unset (defaults to "/") for Vercel, Netlify, or a custom domain.
# VITE_BASE=/your-repo-name/
